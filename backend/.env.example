# Environment Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (PostgreSQL connection string)
DATABASE_URL="postgresql://username:password@localhost:5432/gradeiq_db?schema=public"

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# Email/SMTP Configuration (Optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="GradeIQ Support <your_email@gmail.com>"

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
